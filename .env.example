# 로컬: file:./prisma/dev.db   프로덕션: Neon/Supabase 등 PostgreSQL URL 권장(Netlify 서버리스에서는 SQLite 비권장)
DATABASE_URL="file:./dev.db"
# 배포(Netlify 등) 필수: 없으면 로그인 API가 동작하지 않습니다(16자 이상).
COUNSELOR_JWT_SECRET="change-to-random-32-chars-minimum!!"
COUNSELOR_SEED_EMAIL="counselor@maeum.local"
COUNSELOR_SEED_PASSWORD="your-secure-password"

# (선택) 배포/CI 시드 시 smart1212 계정 비밀번호를 env로 넣으면 SMART_LOGIN_HASH 대신 이 값으로 해시합니다.
# SMART1212_SEED_PASSWORD=

# 상담사 QA 계정(시드): 이메일 smart1212@maeum.local / 아이디 smart1212 동일 매칭
# 배포 후 DB가 비어 있으면 로그인 불가 → 호스트에서 npm run db:push && npm run db:seed (또는 node scripts/verify-counselor-login.cjs 로 검증)
# 비밀번호 해시 변경: prisma/seed.cjs 의 SMART_LOGIN_HASH 를 교체 후 db:seed
